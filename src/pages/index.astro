---
import { getCollection } from 'astro:content';
import ArchiveExplorer from '@/components/ArchiveExplorer.astro';
import Icon from '@/components/Icon.astro';
import StatsStrip from '@/components/StatsStrip.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  formatDate,
  getArchiveStats,
  recordHref,
  typeMeta,
  visibleRecords,
} from '@/lib/records';
import { siteConfig } from '@/site.config';

const records = visibleRecords(await getCollection('records'));
const stats = getArchiveStats(records);
const latest = records[0];
const featured = records.filter((entry) => entry.data.featured).slice(0, siteConfig.home.featuredLimit);
const fallbackFeatured = featured.length > 0 ? featured : records.slice(0, siteConfig.home.featuredLimit);

const recentCutoff = new Date();
recentCutoff.setUTCMonth(recentCutoff.getUTCMonth() - siteConfig.home.recentMonths);
const recentRecords = records.filter((entry) => entry.data.date >= recentCutoff);
const homeRecords = (recentRecords.length > 0 ? recentRecords : records).slice(0, siteConfig.home.recordLimit);
---

<BaseLayout>
  <section class="hero section-shell">
    <div class="hero-copy">
      <p class="eyebrow">A LIVING PERSONAL ARCHIVE</p>
      <h1>日々を一冊ずつ、<br /><em>自分だけの書庫へ。</em></h1>
      <p class="hero-lead">{siteConfig.profile.shortBio}</p>
      <div class="hero-actions">
        <a class="primary-button" href="#catalogue">
          本棚をひらく
          <Icon name="arrow" size={18} />
        </a>
        <a class="secondary-button" href="/about/">この書庫について</a>
      </div>
      {latest && (
        <a class="latest-note" href={recordHref(latest)}>
          <span>NEW</span>
          <div>
            <small>{formatDate(latest.data.date)}</small>
            <strong>{latest.data.title}</strong>
          </div>
          <Icon name="arrow" size={18} />
        </a>
      )}
    </div>

    <div class="hero-archive" aria-label={`現在の収蔵数は${stats.records}冊です`}>
      <div class="archive-window">
        <div class="window-topline"><span>SHIORI ARCHIVE</span><span>EST. {siteConfig.startYear}</span></div>
        <div class="hero-shelf" aria-hidden="true">
          <i class="volume-a"></i>
          <i class="volume-b"></i>
          <i class="volume-c"></i>
          <i class="volume-d"></i>
          <i class="volume-e"></i>
          <i class="volume-f"></i>
        </div>
        <div class="archive-seal">
          <span>VOLUME</span>
          <strong>{String(stats.records).padStart(2, '0')}</strong>
          <small>{siteConfig.owner}</small>
        </div>
        <blockquote>“忘れたくない日は、<br />いつでも戻れる場所に。”</blockquote>
        <div class="window-footer"><span>MEMORY · WORK · LEARNING</span><b>私蔵</b></div>
      </div>
    </div>
  </section>

  <div class="section-shell stats-wrap">
    <StatsStrip stats={stats} />
  </div>

  {records.length === 0 ? (
    <section class="first-record section-shell" id="catalogue">
      <p class="eyebrow">YOUR FIRST VOLUME</p>
      <h2>最初の一冊を収めましょう</h2>
      <p><code>content/records/</code> にMarkdownを追加すると、ここに本棚が育ち始めます。</p>
      <a class="primary-button" href="/about/#add-record">記録の追加方法を見る <Icon name="arrow" size={18} /></a>
    </section>
  ) : (
    <div id="catalogue">
      <ArchiveExplorer records={homeRecords} heading="最近の本棚" description={`直近${siteConfig.home.recentMonths}か月の記録。すべては目録から探せます。`} />
      {homeRecords.length < records.length && (
        <div class="section-shell archive-cta">
          <p>この棚には最近の {homeRecords.length} 冊を並べています。</p>
          <a class="text-link" href="/archive/">全 {records.length} 冊の目録を見る <Icon name="arrow" size={17} /></a>
        </div>
      )}
    </div>
  )}

  {fallbackFeatured.length > 0 && (
    <section class="featured-section section-shell">
      <div class="section-heading">
        <div>
          <p class="eyebrow">BOOKMARKED</p>
          <h2>しおりを挟んだ記録</h2>
          <p>あとで、もう一度読み返したいページ。</p>
        </div>
      </div>
      <div class="featured-grid">
        {fallbackFeatured.map((entry, index) => {
          const meta = typeMeta[entry.data.type];
          return (
            <a class="featured-record" href={recordHref(entry)}>
              <span class="featured-number">0{index + 1}</span>
              <div>
                <span class={`type-chip book-${meta.color}`}>{meta.icon} {meta.label}</span>
                <h3>{entry.data.title}</h3>
                <p>{entry.data.summary}</p>
                <small>{formatDate(entry.data.date)}{entry.data.project ? ` · ${entry.data.project}` : ''}</small>
              </div>
              <Icon name="arrow" size={20} />
            </a>
          );
        })}
      </div>
    </section>
  )}

  <section class="agent-prompt section-shell">
    <div class="prompt-mark" aria-hidden="true"><span>AI</span></div>
    <div>
      <p class="eyebrow">A SMALL REPORT IS ENOUGH</p>
      <h2>「今日これを終えた」と、伝えるだけ。</h2>
      <p>リポジトリを操作できるAIエージェントが <code>AGENTS.md</code> を読み、日付・タグ・保存先を判断して記録します。</p>
    </div>
    <div class="prompt-example">
      <span>依頼例</span>
      <p>「今日は検索画面を完成させた。学んだことと完了タスクを開発記録に追加して」</p>
    </div>
  </section>
</BaseLayout>
