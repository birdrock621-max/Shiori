---
import { getCollection } from 'astro:content';
import ArchiveExplorer from '@/components/ArchiveExplorer.astro';
import StatsStrip from '@/components/StatsStrip.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getArchiveStats, visibleRecords } from '@/lib/records';

const records = visibleRecords(await getCollection('records'));
const stats = getArchiveStats(records);
---

<BaseLayout title="目録" description="日付、年、タグ、種類、プロジェクトから記録を探せるShioriの全目録。">
  <header class="page-hero section-shell">
    <div>
      <p class="eyebrow">THE COMPLETE CATALOGUE</p>
      <h1>書庫の目録</h1>
      <p>積み重なった記録を、年・種類・タグ・プロジェクトから辿れます。</p>
    </div>
    <div class="catalogue-index" aria-hidden="true">
      <span>A—Z</span><i></i><span>01—{String(records.length).padStart(2, '0')}</span>
    </div>
  </header>

  <div class="section-shell stats-wrap compact">
    <StatsStrip stats={stats} />
  </div>

  {records.length > 0 ? (
    <ArchiveExplorer records={records} heading="すべての記録" description="検索条件はURLに残るので、そのまま共有できます。" syncUrl />
  ) : (
    <section class="first-record section-shell">
      <h2>目録はまだ空です</h2>
      <p>最初のMarkdownを追加すると、ここに記録が並びます。</p>
      <a class="primary-button" href="/about/#add-record">追加方法を見る</a>
    </section>
  )}
</BaseLayout>
