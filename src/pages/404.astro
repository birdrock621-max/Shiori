---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
---

<BaseLayout title="ページが見つかりません" noindex>
  <section class="not-found section-shell">
    <div class="missing-volume" aria-hidden="true"><span>404</span></div>
    <p class="eyebrow">MISSING FROM THE SHELF</p>
    <h1>その本は、棚に見つかりませんでした。</h1>
    <p>移動したか、まだ書かれていない記録かもしれません。</p>
    <div class="hero-actions">
      <a class="primary-button" href="/">本棚へ戻る <Icon name="arrow" size={18} /></a>
      <a class="secondary-button" href="/archive/">目録から探す</a>
    </div>
  </section>
</BaseLayout>
