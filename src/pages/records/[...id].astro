---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Icon from '@/components/Icon.astro';
import {
  estimateReadingMinutes,
  formatDate,
  recordHref,
  typeMeta,
  visibleRecords,
} from '@/lib/records';
import { siteConfig } from '@/site.config';

export async function getStaticPaths() {
  const records = visibleRecords(await getCollection('records'));
  return records.map((entry) => ({ params: { id: entry.id }, props: { entry, records } }));
}

interface Props {
  entry: CollectionEntry<'records'>;
  records: CollectionEntry<'records'>[];
}

const { entry, records } = Astro.props;
const { Content, headings } = await render(entry);
const meta = typeMeta[entry.data.type];
const currentIndex = records.findIndex((candidate) => candidate.id === entry.id);
const newer = currentIndex > 0 ? records[currentIndex - 1] : undefined;
const older = currentIndex < records.length - 1 ? records[currentIndex + 1] : undefined;
const readingMinutes = estimateReadingMinutes(entry.body);
const tasksDone = entry.data.tasks.filter((task) => task.done).length;
const hasToc = headings.filter((heading) => heading.depth <= 3).length >= 3;
---

<BaseLayout title={entry.data.title} description={entry.data.summary} image={entry.data.cover} article>
  <article class="record-page">
    <header class="record-hero section-shell">
      <nav class="breadcrumb" aria-label="パンくずリスト">
        <a href="/">本棚</a><span aria-hidden="true">/</span><a href="/archive/">目録</a><span aria-hidden="true">/</span><span>{meta.label}</span>
      </nav>
      <div class="record-title-grid">
        <div>
          <div class="record-kicker">
            <span class={`type-chip book-${meta.color}`}>{meta.icon} {meta.label}</span>
            {entry.data.project && <a href={`/archive/?project=${encodeURIComponent(entry.data.project)}`}>{entry.data.project}</a>}
          </div>
          <h1>{entry.data.title}</h1>
          <p class="record-summary">{entry.data.summary}</p>
          <div class="record-byline">
            <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date, siteConfig.locale)}</time>
            <span>{readingMinutes}分で読めます</span>
            {entry.data.updated && <span>更新 {formatDate(entry.data.updated, siteConfig.locale)}</span>}
          </div>
        </div>
        <div class={`record-volume book-${meta.color}`} aria-hidden="true">
          <span>{entry.data.date.getUTCFullYear()}</span>
          <strong>{String(entry.data.date.getUTCMonth() + 1).padStart(2, '0')}<i>/</i>{String(entry.data.date.getUTCDate()).padStart(2, '0')}</strong>
          <small>{meta.label.toUpperCase()}</small>
        </div>
      </div>
      {entry.data.tags.length > 0 && (
        <ul class="record-tags" aria-label="タグ">
          {entry.data.tags.map((tag) => <li><a href={`/archive/?tag=${encodeURIComponent(tag)}`}>#{tag}</a></li>)}
        </ul>
      )}
    </header>

    {entry.data.cover && (
      <figure class="record-cover section-shell">
        <img src={entry.data.cover} alt={entry.data.cover_alt} loading="eager" decoding="async" />
      </figure>
    )}

    <div class={`reading-layout section-shell ${hasToc ? 'has-toc' : ''}`}>
      {hasToc && (
        <aside class="toc" aria-label="目次">
          <p>この記録の目次</p>
          <ol>
            {headings.filter((heading) => heading.depth <= 3).map((heading) => (
              <li class={`depth-${heading.depth}`}><a href={`#${heading.slug}`}>{heading.text}</a></li>
            ))}
          </ol>
        </aside>
      )}

      <div class="reading-column">
        {entry.data.tasks.length > 0 && (
          <section class="task-ledger" aria-labelledby="task-ledger-title">
            <header>
              <div><span>COMPLETION LOG</span><h2 id="task-ledger-title">この記録の完了タスク</h2></div>
              <strong>{tasksDone}<small> / {entry.data.tasks.length}</small></strong>
            </header>
            <ul>
              {entry.data.tasks.map((task) => (
                <li class:list={{ done: task.done }}>
                  <span aria-hidden="true">{task.done ? '✓' : '–'}</span>
                  <span>{task.text}</span>
                  <span class="sr-only">{task.done ? '完了' : '未完了'}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <div class="prose">
          <Content />
        </div>

        <footer class="record-end">
          <div class="end-mark" aria-hidden="true">＊</div>
          <p>{siteConfig.name} · {formatDate(entry.data.date, siteConfig.locale)}</p>
          <button type="button" data-copy-url><Icon name="link" size={16} /><span>この記録のURLをコピー</span></button>
        </footer>
      </div>
    </div>

    <nav class="record-pagination section-shell" aria-label="前後の記録">
      {newer ? (
        <a href={recordHref(newer)} class="newer"><span>← 新しい記録</span><strong>{newer.data.title}</strong></a>
      ) : <span></span>}
      {older ? (
        <a href={recordHref(older)} class="older"><span>古い記録 →</span><strong>{older.data.title}</strong></a>
      ) : <span></span>}
    </nav>
  </article>
</BaseLayout>

<script>
  document.querySelector('[data-copy-url]')?.addEventListener('click', async (event) => {
    await navigator.clipboard.writeText(location.href);
    const button = event.currentTarget;
    if (!(button instanceof HTMLButtonElement)) return;
    const label = button.querySelector('span');
    if (!label) return;
    const original = label.textContent;
    label.textContent = 'コピーしました';
    setTimeout(() => { label.textContent = original; }, 1800);
  });
</script>
