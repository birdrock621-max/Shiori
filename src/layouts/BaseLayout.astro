---
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import { siteConfig } from '@/site.config';
import '@/styles/global.css';
import '@/styles/immersive.css';
import '@/styles/immersive-hero.css';
import '@/styles/immersive-sections.css';
import '@/styles/immersive-responsive.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  noindex?: boolean;
  pageClass?: string;
  preloadImage?: string;
}

const { title, description = siteConfig.description, image, article = false, noindex = false, pageClass, preloadImage } = Astro.props;
const pageTitle = title ? `${title} — ${siteConfig.name}` : `${siteConfig.name} — 日々を収める私の書庫`;
const preloadOrigin = preloadImage?.startsWith('http') ? new URL(preloadImage).origin : undefined;
---

<!doctype html>
<html lang={siteConfig.language} data-theme="light" data-theme-preference="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090a09" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f2ecdf" media="(prefers-color-scheme: light)" />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {preloadOrigin && <link rel="preconnect" href={preloadOrigin} crossorigin />}
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}
    <script is:inline src="/theme-init.js"></script>
    <title>{pageTitle}</title>
    <slot name="head" />
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main-content">本文へ移動</a>
    <SiteHeader />
    <main id="main-content" tabindex="-1"><slot /></main>
    <SiteFooter />
  </body>
</html>
