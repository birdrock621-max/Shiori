---
import Icon from './Icon.astro';
import { siteConfig } from '@/site.config';

const path = Astro.url.pathname;
const isHome = path === '/';
---

<header class:list={['site-header', { 'site-header--home': isHome }]} data-site-header>
  <div class="header-inner">
    <a class="wordmark" href="/" aria-label={`${siteConfig.name} ホーム`}>
      <svg class="wordmark-logo" width="26" height="26" viewBox="0 0 256 256" aria-hidden="true"><path d="M 256 256 L 128 256 L 0 128 L 128 128 Z M 256 128 L 128 128 L 0 0 L 128 0 Z"></path></svg>
      <span class="wordmark-name">{siteConfig.name}</span><small>personal archive</small>
    </a>

    <nav class="primary-nav" aria-label="メインナビゲーション">
      <a href="/" aria-current={path === '/' ? 'page' : undefined}>本棚</a>
      <a href="/archive/" aria-current={path.startsWith('/archive') ? 'page' : undefined}>すべての記録</a>
      <a href="/archive/#catalogue">タグとプロジェクト</a>
      <a href="/about/" aria-current={path.startsWith('/about') ? 'page' : undefined}>この書庫</a>
    </nav>

    <div class="header-actions">
      <a class="header-cta" href="/archive/">書庫をひらく</a>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="表示テーマを切り替える" title="表示テーマを切り替える">
        <span data-theme-icon="system"><Icon name="system" size={18} /></span><span data-theme-icon="light" hidden><Icon name="sun" size={18} /></span><span data-theme-icon="dark" hidden><Icon name="moon" size={18} /></span><span class="sr-only" data-theme-label>端末に合わせる</span>
      </button>
      <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-controls="mobile-navigation" aria-label="メニューを開く"><span></span><span></span></button>
    </div>
  </div>

  <div class="mobile-navigation" id="mobile-navigation" data-mobile-navigation hidden>
    <div class="mobile-navigation-inner">
      <p>EXPLORE THE ARCHIVE</p>
      <nav aria-label="モバイルナビゲーション">
        <a href="/" aria-current={path === '/' ? 'page' : undefined}><span>01</span>本棚</a>
        <a href="/archive/" aria-current={path.startsWith('/archive') ? 'page' : undefined}><span>02</span>すべての記録</a>
        <a href="/archive/#catalogue"><span>03</span>タグとプロジェクト</a>
        <a href="/about/" aria-current={path.startsWith('/about') ? 'page' : undefined}><span>04</span>この書庫</a>
      </nav>
      <small>日々の記録を、時間の層として残す。</small>
    </div>
  </div>
  <noscript><nav class="noscript-navigation" aria-label="JavaScript無効時のナビゲーション"><a href="/">本棚</a><a href="/archive/">すべての記録</a><a href="/archive/#catalogue">タグとプロジェクト</a><a href="/about/">この書庫</a></nav></noscript>
</header>

<script>
  type ThemePreference = 'system' | 'light' | 'dark';
  const labels = { system: '端末に合わせる', light: '明るいテーマ', dark: '暗いテーマ' };
  const order: ThemePreference[] = ['system', 'light', 'dark'];

  function applyTheme(theme: ThemePreference) {
    const resolved = theme === 'system' ? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : theme;
    document.documentElement.dataset.theme = resolved;
    document.documentElement.dataset.themePreference = theme;
    document.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((icon) => { icon.hidden = icon.dataset.themeIcon !== theme; });
    document.querySelectorAll<HTMLElement>('[data-theme-label]').forEach((label) => { label.textContent = labels[theme]; });
  }

  document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const current = (document.documentElement.dataset.themePreference || 'system') as ThemePreference;
      const next = order[(order.indexOf(current) + 1) % order.length];
      if (!next) return;
      localStorage.setItem('shiori-theme', next);
      applyTheme(next);
    });
  });

  matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if ((document.documentElement.dataset.themePreference || 'system') === 'system') applyTheme('system');
  });

  document.querySelectorAll<HTMLElement>('[data-site-header]').forEach((header) => {
    const toggle = header.querySelector<HTMLButtonElement>('[data-menu-toggle]');
    const panel = header.querySelector<HTMLElement>('[data-mobile-navigation]');
    if (!toggle || !panel) return;
    const setPageInert = (inert: boolean) => {
      const pageRegions = [
        document.querySelector<HTMLElement>('main'),
        document.querySelector<HTMLElement>('footer'),
      ];
      pageRegions.forEach((element) => {
        if (!element) return;
        if (inert) element.setAttribute('inert', '');
        else element.removeAttribute('inert');
      });
    };
    const closeMenu = (restoreFocus = false) => { panel.hidden = true; header.classList.remove('menu-is-open'); toggle.setAttribute('aria-expanded', 'false'); toggle.setAttribute('aria-label', 'メニューを開く'); document.documentElement.classList.remove('menu-lock'); setPageInert(false); if (restoreFocus) toggle.focus(); };
    const openMenu = () => { panel.hidden = false; header.classList.add('menu-is-open'); toggle.setAttribute('aria-expanded', 'true'); toggle.setAttribute('aria-label', 'メニューを閉じる'); document.documentElement.classList.add('menu-lock'); setPageInert(true); panel.querySelector<HTMLAnchorElement>('a')?.focus(); };
    toggle.addEventListener('click', () => toggle.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu());
    panel.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => closeMenu()));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && !panel.hidden) closeMenu(true); });
    const updateHeader = () => {
      const hero = document.querySelector<HTMLElement>('[data-immersive-hero]');
      header.classList.toggle('is-scrolled', Boolean(hero && hero.getBoundingClientRect().bottom <= 92));
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateHeader, { once: true });
    } else {
      updateHeader();
    }
    addEventListener('scroll', updateHeader, { passive: true });
    addEventListener('resize', () => { updateHeader(); if (innerWidth > 760 && !panel.hidden) closeMenu(); }, { passive: true });
  });
</script>
