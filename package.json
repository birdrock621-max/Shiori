{
  "name": "shiori",
  "version": "2.0.0",
  "private": true,
  "description": "A multilingual, zero-configuration static bookshelf for Markdown journals and activity logs.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "preview": "node scripts/serve.mjs dist",
    "check": "node scripts/check.mjs",
    "test": "node --test",
    "smoke": "node scripts/smoke.mjs dist",
    "contrast": "node scripts/contrast.mjs",
    "test:scenarios": "node scripts/verify-scenarios.mjs",
    "test:all": "npm run check && npm run contrast && npm test && npm run build && npm run smoke && npm run test:scenarios",
    "clean": "node -e \"import('node:fs/promises').then(({rm})=>rm('dist',{recursive:true,force:true}))\""
  },
  "engines": { "node": ">=22.0.0" },
  "keywords": ["journal", "markdown", "multilingual", "static-site-generator", "cloudflare-pages", "bookshelf"],
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/birdrock621-max/Shiori.git" },
  "bugs": { "url": "https://github.com/birdrock621-max/Shiori/issues" },
  "homepage": "https://github.com/birdrock621-max/Shiori#readme"
}
